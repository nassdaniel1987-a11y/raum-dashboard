# Supabase Konfiguration
# Diese Werte erhältst du aus deinem Supabase Projekt unter Settings > API

PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# Service Role Key für Netlify Scheduled Functions (Keep-Alive Mechanismus)
# Wird verwendet, um die Datenbank alle 7 Tage aktiv zu halten
# ⚠️ SICHERHEITSWARNHINWEIS: Niemals committen oder öffentlich teilen!
# Diese Variable sollte nur in der Netlify Umgebung konfiguriert werden
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key-hier

# Blitz-Protokoll Integration (optional)
# API-URL zum Blitz-Protokoll Endpunkt
BLITZ_PROTOKOLL_API_URL=https://blitz-protokoll.netlify.app/api/raumuebersicht
# API-Key zur Authentifizierung (muss mit dem Blitz-Protokoll übereinstimmen)
BLITZ_PROTOKOLL_API_KEY=dein-blitz-api-key-hier

# WICHTIG: Erstelle eine echte .env Datei mit deinen tatsächlichen Werten
# Die .env Datei ist in .gitignore und wird nicht committet
